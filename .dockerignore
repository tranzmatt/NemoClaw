# Security: secrets, credentials, and keys
# Mirror .gitignore security patterns to prevent sensitive files from
# being sent to the Docker daemon and permanently baked into image layers.
.env
.env.*
.envrc
.npmrc
.netrc
.pypirc
.direnv/
.ssh/
secrets/
.credentials
*.key
*.pem
*.pfx
*.p12
*.jks
*.keystore
*.tfvars
*_ecdsa
*_ed25519
*_rsa
credentials.json
key.json
secrets.json
secrets.yaml
service-account*.json
token.json
